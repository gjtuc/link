OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (권장) — 상황별 이원화
GEMINI_API_KEY=
GEMINI_MODEL_FLASH=gemini-3.5-flash
GEMINI_MODEL_PRO=gemini-3.1-pro-preview
# thinking: minimal | low | medium | high
GEMINI_THINKING_LEVEL_FLASH=medium
GEMINI_THINKING_LEVEL_PRO=high
LLM_PROVIDER=auto

# Tavily — Dreamer 가설 Fact-Checker 웹 검색 (https://app.tavily.com/home)
TAVILY_API_KEY=
# 1/true/yes — 키가 있어도 Tavily 호출 안 함 (테스트·과금 방지)
TAVILY_DISABLED=

# document (기본) — PDF/DOCX 요약 없이 청크 분해 | summarize — 레거시 2–5문장 요약
LINK_DOCUMENT_INGEST=document
# PDF 최대 페이지 (0=무제한)
DOC_PDF_MAX_PAGES=100

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

MAX_DECOMPOSITION_ITERATIONS=5
